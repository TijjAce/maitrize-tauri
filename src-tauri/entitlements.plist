<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Distribution Developer ID (hors App Store).
         On N'utilise PAS l'App Sandbox ni com.apple.application-identifier :
         ces clés exigent un provisioning profile embarqué (réservé au Mac App
         Store) et, en distribution directe, empêchent l'app de se lancer.
         Le Hardened Runtime (requis pour la notarisation) est appliqué à la
         signature ; les exceptions ci-dessous permettent au moteur WebView
         de Tauri de fonctionner sous Hardened Runtime. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
